rules_version = '2';

// ===== Firestore Security Rules — websangudom =====
//
// Read Access: Public (catalog visible without login)
// Write Access: Admin only (restricted by UID)
//
// SECURITY NOTES:
// 1. Email/Password auth allows anyone to create accounts via public API key
//    → Must restrict writes to specific UID, not just auth != null
// 2. Admin UID is NOT hardcoded here for security
//    → Set in Firebase Console Rules editor at deploy time
//    → OR use Cloud Functions to manage permissions
// 3. For production, consider:
//    - Custom claims for role-based access
//    - Cloud Functions for audit logging
//    - IP whitelisting for admin operations
//
// DEPLOYMENT:
// 1. Set ADMIN_UID variable in Firebase Console Rules editor
// 2. Or use: firebase deploy --only firestore:rules
// 3. Or run: https://console.firebase.google.com/ → Firestore → Rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Security Functions =====
    // Admin UID - MUST BE SET in Firebase Console before deployment
    // DO NOT hardcode in version control
    function getAdminUID() {
      // Load from Firestore custom resource or environment
      // This should be replaced with actual admin UID at deployment
      return get(/databases/$(database)/documents/config/admin).data.uid;
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == getAdminUID();
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ===== Collection Rules =====

    // สินค้า — อ่านสาธารณะ, เขียน/ลบเฉพาะแอดมิน
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // อย่างอื่นทั้งหมด — ปิดหมด (กันสร้าง collection มั่วๆ)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
