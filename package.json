{
  "name": "sang-udom-lighting",
  "version": "1.0.0",
  "description": "Sang Udom Lighting Centre - Product Catalog & Admin Management System",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom='js/**/*.js'",
    "test:unit": "jest tests/*.test.js",
    "test:validation": "jest tests/validation.test.js",
    "test:errors": "jest tests/error-handler.test.js",
    "test:repository": "jest tests/product-repository.test.js",
    "test:analytics": "jest tests/analytics.test.js",
    "test:performance": "jest tests/performance-monitor.test.js",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint js/ --fix",
    "firebase:emulate": "firebase emulators:start",
    "firebase:deploy": "firebase deploy",
    "firebase:functions:deploy": "firebase deploy --only functions"
  },
  "keywords": [
    "firebase",
    "firestore",
    "e-commerce",
    "lighting",
    "catalog"
  ],
  "author": "Anirut Dev",
  "license": "MIT",
  "dependencies": {
    "firebase": "^11.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}
