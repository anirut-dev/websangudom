# Firebase Configuration
# Copy this file to .env and fill in with your actual values
# Never commit .env file to git - it contains sensitive information

# Firebase Project Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Admin User UID (from Firebase Authentication)
# This user will have exclusive write access to the Firestore database
# Find this in Firebase Console > Authentication > Users > User UID
FIREBASE_ADMIN_UID=your_admin_uid_here

# Cloudinary Configuration (for product image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_preset_name

# Environment
NODE_ENV=development
